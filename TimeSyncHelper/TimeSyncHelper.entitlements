<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Helper runs as root via launchd. Needs to:
        - listen on a Mach service (allowed)
        - validate caller's SecCode (allowed)
        - spawn /opt/homebrew/bin/chronyc (Process; no entitlement needed)
        - call settimeofday(2) [legacy, no longer used] — root can do this
          regardless of entitlements
    -->
</dict>
</plist>
